# Local database
DATABASE_URL="postgresql://postgres:password@localhost:5433/beuntethered_local?schema=public"

# App/auth
NEXTAUTH_URL="http://127.0.0.1:3200"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXT_PUBLIC_APP_URL="http://127.0.0.1:3200"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Vercel Blob attachments
# Leave blank/fake locally to use the built-in local.blob test fallback.
BLOB_READ_WRITE_TOKEN="test_token_local_blob_fallback"

# AI providers
OPENAI_API_KEY=""
MINIMAX_API_KEY=""
MINIMAX_BASE_URL="https://api.minimax.io/v1"

# Basic-task AI lane for cheap triage/classification/summary work.
# Supported values: groq, gemma-4-server, minimax.
AI_BASIC_PROVIDER="groq"
GROQ_API_KEY=""
GROQ_BASE_URL="https://api.groq.com/openai/v1"
GROQ_MODEL="llama-3.1-8b-instant"

# Optional self-hosted Gemma server route.
# Point this at an OpenAI-compatible endpoint from vLLM, llama.cpp, Ollama /v1, NVIDIA NIM, or a private gateway.
GEMMA_BASE_URL=""
GEMMA_MODEL="gemma-4-26b-it"
GEMMA_API_KEY=""

# Encryption for API keys at rest (AES-256-GCM)
# Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY="replace-with-64-char-hex-secret"

# Platform API Secret (used for SSRF protection between internal services)
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET="your-internal-api-secret-here"

# Vercel Cron Secret (sent as Authorization: Bearer $CRON_SECRET)
# Generate with: openssl rand -hex 32
CRON_SECRET="your-cron-secret-here"

# Admin email for disputes
ADMIN_EMAIL="admin@untether.network"

# Email notifications
RESEND_API_KEY=""
EMAIL_FROM="Untether <notifications@untether.network>"

# Not used in this release:
# - Firebase push notifications are not configured; in-app notifications are stored in Postgres.
# - SMS is intentionally out of scope.

# OAuth providers
GITHUB_ID=""
GITHUB_SECRET=""
GITHUB_WEBHOOK_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
