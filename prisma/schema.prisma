generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  DEVELOPER
  CLIENT
}

enum SubscriptionTier {
  FREE
  BYOC_PRO
}

model User {
  id                 String  @id @default(uuid())
  email              String  @unique
  emailVerified      DateTime?
  image              String?
  name               String?
  role               Role             @default(CLIENT)
  stripe_account_id  String? // for payouts via Connect
  stripe_customer_id String? // for billing via Stripe
  subscription_tier  SubscriptionTier @default(FREE)
  
  projects_as_client    Project[] @relation("ClientProjects")
  projects_as_developer Project[] @relation("DeveloperProjects")
  bids                  Bid[]
  messages              Message[]
  accounts              Account[]
  sessions              Session[]
}

enum ProjectStatus {
  DRAFT
  OPEN_BIDDING
  ACTIVE
  COMPLETED
  DISPUTED
}

model Project {
  id                 String  @id @default(uuid())
  client_id          String
  developer_id       String?
  title              String
  ai_generated_sow   String  @db.Text
  is_byoc            Boolean @default(false)
  status             ProjectStatus @default(DRAFT)

  client             User      @relation("ClientProjects", fields: [client_id], references: [id])
  developer          User?     @relation("DeveloperProjects", fields: [developer_id], references: [id])
  
  bids               Bid[]
  milestones         Milestone[]
  change_orders      ChangeOrder[]
  messages           Message[]
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Bid {
  id                     String  @id @default(uuid())
  project_id             String
  developer_id           String
  proposed_amount        Decimal
  estimated_days         Int
  technical_approach     String  @db.Text
  ai_translation_summary String  @db.Text
  status                 BidStatus @default(PENDING)

  project                Project @relation(fields: [project_id], references: [id])
  developer              User    @relation(fields: [developer_id], references: [id])
}

enum MilestoneStatus {
  PENDING
  FUNDED_IN_ESCROW
  SUBMITTED_FOR_REVIEW
  APPROVED_AND_PAID
  DISPUTED
}

model Milestone {
  id                       String  @id @default(uuid())
  project_id               String
  title                    String
  amount                   Decimal
  status                   MilestoneStatus @default(PENDING)
  stripe_payment_intent_id String?

  project                  Project @relation(fields: [project_id], references: [id])
}

enum ChangeOrderStatus {
  PROPOSED
  ACCEPTED_AND_FUNDED
  REJECTED
}

model ChangeOrder {
  id          String  @id @default(uuid())
  project_id  String
  description String
  added_cost  Decimal
  status      ChangeOrderStatus @default(PROPOSED)

  project     Project @relation(fields: [project_id], references: [id])
}

model Message {
  id                 String  @id @default(uuid())
  project_id         String
  sender_id          String?
  content            String  @db.Text
  is_system_message  Boolean @default(false)

  project            Project @relation(fields: [project_id], references: [id])
  sender             User?   @relation(fields: [sender_id], references: [id])
}

// --- NEXTAUTH REQUIRED MODELS ---

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
