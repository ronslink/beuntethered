generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Bid {
  id                     String    @id @default(cuid())
  project_id             String
  developer_id           String
  proposed_amount        Decimal
  estimated_days         Int
  technical_approach     String
  ai_translation_summary String
  status                 BidStatus @default(PENDING)
  developer              User      @relation(fields: [developer_id], references: [id])
  project                Project   @relation(fields: [project_id], references: [id])
}

model ChangeOrder {
  id          String            @id @default(cuid())
  project_id  String
  description String
  added_cost  Decimal
  status      ChangeOrderStatus @default(PROPOSED)
  project     Project           @relation(fields: [project_id], references: [id])
}

model Message {
  id                String     @id @default(cuid())
  project_id        String
  milestone_id      String?
  sender_id         String?
  content           String
  is_system_message Boolean    @default(false)
  created_at        DateTime   @default(now())
  milestone         Milestone? @relation(fields: [milestone_id], references: [id])
  project           Project    @relation(fields: [project_id], references: [id])
  sender            User?      @relation(fields: [sender_id], references: [id])
}

model Milestone {
  id                       String          @id @default(cuid())
  project_id               String
  facilitator_id           String?
  title                    String
  amount                   Decimal
  status                   MilestoneStatus @default(PENDING)
  stripe_payment_intent_id String?
  acceptance_criteria      String[]
  deliverables             String[]
  description              String?
  estimated_duration_days  Int?
  messages                 Message[]
  facilitator              User?           @relation(fields: [facilitator_id], references: [id])
  project                  Project         @relation(fields: [project_id], references: [id])
  squad_members            SquadMember[]
  live_preview_url         String?
  payload_storage_path     String?
  disputes                 Dispute[]
  timeline_events          TimelineEvent[]
}

model Project {
  id                     String          @id @default(cuid())
  creator_id             String
  client_id              String?
  title                  String
  ai_generated_sow       String
  is_byoc                Boolean         @default(false)
  billing_type           BillingType     @default(FIXED_MILESTONE)
  github_repo_url        String?
  github_access_token    String?
  invite_token           String?         @unique
  status                 ProjectStatus   @default(DRAFT)
  created_at             DateTime        @default(now())
  bids                   Bid[]
  change_orders          ChangeOrder[]
  messages               Message[]
  milestones             Milestone[]
  client                 User?           @relation("Project_client_idToUser", fields: [client_id], references: [id])
  creator                User            @relation("Project_creator_idToUser", fields: [creator_id], references: [id])
  reviews                Review[]
  squad_proposals        SquadProposal[]
  disputes               Dispute[]
  timeline_events        TimelineEvent[]
}

model Review {
  id             String   @id @default(cuid())
  project_id     String
  client_id      String
  facilitator_id String
  rating         Int
  feedback       String
  created_at     DateTime @default(now())
  client         User     @relation("Review_client_idToUser", fields: [client_id], references: [id])
  facilitator    User     @relation("Review_facilitator_idToUser", fields: [facilitator_id], references: [id])
  project        Project  @relation(fields: [project_id], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SquadMember {
  id                String        @id @default(cuid())
  squad_proposal_id String
  facilitator_id    String
  milestone_id      String
  facilitator       User          @relation(fields: [facilitator_id], references: [id])
  milestone         Milestone     @relation(fields: [milestone_id], references: [id])
  squad_proposal    SquadProposal @relation(fields: [squad_proposal_id], references: [id])
}

model SquadProposal {
  id              String        @id @default(cuid())
  project_id      String
  pitch_to_client String
  status          BidStatus     @default(PENDING)
  members         SquadMember[]
  project         Project       @relation(fields: [project_id], references: [id])
}

model Dispute {
  id                     String        @id @default(cuid())
  project_id             String
  milestone_id           String
  client_id              String
  facilitator_id         String
  reason                 String
  appmap_log_url         String?
  ai_fact_finding_report String?
  status                 DisputeStatus @default(OPEN)
  created_at             DateTime      @default(now())

  project     Project   @relation(fields: [project_id], references: [id])
  milestone   Milestone @relation(fields: [milestone_id], references: [id])
  client      User      @relation("Dispute_client_idToUser", fields: [client_id], references: [id])
  facilitator User      @relation("Dispute_facilitator_idToUser", fields: [facilitator_id], references: [id])
}

model User {
  id                      String                       @id @default(cuid())
  email                   String                       @unique
  emailVerified           DateTime?
  image                   String?
  name                    String?
  role                    Role                         @default(CLIENT)
  stripe_account_id       String?
  stripe_customer_id      String?
  subscription_tier       SubscriptionTier             @default(FREE)
  expertise_embedding     Unsupported("vector(1536)")?
  password_hash           String?
  openai_key              String?
  anthropic_key           String?
  openai_key_encrypted    String?
  anthropic_key_encrypted String?
  openai_key_plaintext    String?
  anthropic_key_plaintext String?
  preferred_llm           String                       @default("gpt-4o-mini")
  hourly_rate             Decimal                      @default(0)
  platform_tier           PlatformTier                 @default(STANDARD)
  agent_key_hash          String?                      @unique
  trust_score             Float                        @default(0.0)
  total_sprints_completed Int                          @default(0)
  average_ai_audit_score  Float                        @default(0.0)
  accounts                Account[]
  bids                    Bid[]
  messages                Message[]
  milestones              Milestone[]
  client_projects         Project[]                    @relation("Project_client_idToUser")
  created_projects        Project[]                    @relation("Project_creator_idToUser")
  client_reviews          Review[]                     @relation("Review_client_idToUser")
  reviews_received        Review[]                     @relation("Review_facilitator_idToUser")
  client_disputes         Dispute[]                    @relation("Dispute_client_idToUser")
  facilitator_disputes    Dispute[]                    @relation("Dispute_facilitator_idToUser")
  sessions                Session[]
  squad_members           SquadMember[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String    @id @default(cuid())
  email   String
  token   String    @unique
  expires DateTime
  used_at DateTime?

  @@index([email])
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum BillingType {
  FIXED_MILESTONE
  HOURLY_RETAINER
}

enum ChangeOrderStatus {
  PROPOSED
  ACCEPTED_AND_FUNDED
  REJECTED
}

enum MilestoneStatus {
  PENDING
  FUNDED_IN_ESCROW
  SUBMITTED_FOR_REVIEW
  APPROVED_AND_PAID
  DISPUTED
}

enum PlatformTier {
  STANDARD
  PRO
  ELITE
}

enum TimelineEventType {
  COMMIT
  MILESTONE
  REVIEW
  DISPUTE
  SYSTEM
}

enum TimelineEventStatus {
  SUCCESS
  PENDING
  FAILED
}

model TimelineEvent {
  id           String              @id @default(cuid())
  project_id   String
  milestone_id String?
  type         TimelineEventType
  timestamp    DateTime            @default(now())
  description  String
  status       TimelineEventStatus
  author       String
  commitHash   String?

  project   Project    @relation(fields: [project_id], references: [id])
  milestone Milestone? @relation(fields: [milestone_id], references: [id])
}

enum ProjectStatus {
  DRAFT
  OPEN_BIDDING
  ACTIVE
  COMPLETED
  DISPUTED
}

enum Role {
  FACILITATOR
  CLIENT
}

enum SubscriptionTier {
  FREE
  BYOC_PRO
}

enum DisputeStatus {
  OPEN
  RESOLVED_CLIENT
  RESOLVED_FACILITATOR
}
